# Buddy — environment template (DOCUMENTATION ONLY; safe to commit).
# On Replit these are injected as Secrets — do not create a real .env there.
# For LOCAL DEV on your own machine, copy this to a shell export or use a tool like dotenv-cli.

# ── Auto-injected by Replit (do not set by hand on Replit) ──────────────────
DATABASE_URL=postgres://user:password@host:5432/buddy   # Replit PostgreSQL injects this. Locally: your Postgres URL.
SESSION_SECRET=replace-with-a-long-random-string         # Replit Auth injects this. Locally: any random string.
REPL_ID=your-repl-id                                      # Replit Auth (OIDC client id). Leave unset locally.
REPLIT_DOMAINS=your-repl.replit.app                       # Replit Auth (comma-separated hosts). Leave unset locally.
ISSUER_URL=https://replit.com/oidc                        # Replit Auth OIDC issuer (default shown).

# ── Add by hand in the Replit Secrets pane (or your local shell) ────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx             # Claude moderation. Without it, moderation no-ops gracefully.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx            # Gift-card redemption.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx              # Optional; if absent, webhook signature check is skipped.

# ── Local-dev-only flags (ignored on Replit) ───────────────────────────────
# When REPLIT_DOMAINS is absent, Buddy enables a DEV fake-login so you can run on Windows
# without Replit OIDC. Set DEV_AUTH=off to force-disable it.
DEV_AUTH=on
# Email the dev fake-login signs you in as (must pass the .edu check).
DEV_USER_EMAIL=demo@university.edu
